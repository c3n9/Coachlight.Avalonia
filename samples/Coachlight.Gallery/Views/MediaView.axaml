<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cl="clr-namespace:Coachlight.Avalonia.Targeting;assembly=Coachlight.Avalonia"
             xmlns:vm="clr-namespace:Coachlight.Gallery.ViewModels"
             x:Class="Coachlight.Gallery.Views.MediaView"
             x:DataType="vm:MediaPageViewModel">

    <StackPanel Spacing="14" Margin="28" Width="360"
                HorizontalAlignment="Left" VerticalAlignment="Top">
        <TextBlock Text="Media" FontSize="22" FontWeight="SemiBold" />
        <TextBlock Text="A second view model with a second tour, started by the Profile tour."
                   Foreground="Gray" TextWrapping="Wrap" />

        <StackPanel Spacing="4">
            <TextBlock Text="Volume" />
            <Slider x:Name="VolumeSlider"
                    cl:Coachmark.Id="volumeSlider"
                    Minimum="0" Maximum="100"
                    Value="{Binding Volume}" />
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="Recent items" />
            <ListBox x:Name="RecentItemsList"
                     cl:Coachmark.Id="recentItemsList"
                     Height="110"
                     ItemsSource="{Binding RecentItems}" />
        </StackPanel>

        <Button x:Name="OpenActionsBtn"
                cl:Coachmark.Id="openActionsBtn"
                Margin="0,10,0,0"
                Content="Open Actions ➜"
                Command="{Binding OpenActionsCommand}" />
    </StackPanel>
</UserControl>
