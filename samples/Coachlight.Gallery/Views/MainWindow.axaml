<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Coachlight.Gallery.Views"
        xmlns:vm="clr-namespace:Coachlight.Gallery.ViewModels"
        x:Class="Coachlight.Gallery.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        MinWidth="860" MinHeight="640"
        Title="Coachlight Gallery">

    <DockPanel>
        <Border DockPanel.Dock="Bottom" BorderThickness="0,1,0,0" BorderBrush="#22808080">
            <StackPanel Orientation="Horizontal" Spacing="16" Margin="28,14">
                <Button x:Name="StartTourBtn"
                        Content="▶ Start tour"
                        Command="{Binding StartTourCommand}"
                        CommandParameter="{Binding $parent[Window]}" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="Gray"
                           Text="Each page runs its own tour; they hand off to each other and come back." />
            </StackPanel>
        </Border>

        <!-- Only the selected tab's content lives in the visual tree, so each tour only ever
             resolves targets on its own page. -->
        <TabControl SelectedIndex="{Binding SelectedPageIndex}" TabStripPlacement="Left">
            <TabItem Header="Profile">
                <views:ProfileView DataContext="{Binding Profile}" />
            </TabItem>
            <TabItem Header="Media">
                <views:MediaView DataContext="{Binding Media}" />
            </TabItem>
            <TabItem Header="Actions">
                <views:ActionsView DataContext="{Binding Actions}" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
