<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cl="clr-namespace:Coachlight.Avalonia.Targeting;assembly=Coachlight.Avalonia"
             xmlns:vm="clr-namespace:Coachlight.Gallery.ViewModels"
             x:Class="Coachlight.Gallery.Views.ActionsView"
             x:DataType="vm:ActionsPageViewModel">

    <Grid Margin="28">
        <StackPanel Spacing="14" Width="360"
                    HorizontalAlignment="Left" VerticalAlignment="Top">
            <TextBlock Text="Actions" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="The third view model and the third tour. It returns to the Media tour when finished."
                       Foreground="Gray" TextWrapping="Wrap" />
            <TextBlock Text="{Binding Status, StringFormat='Status: {0}'}" Foreground="Gray" />
        </StackPanel>

        <!-- Moves on every press and eventually hides itself, so the spotlight has something
             that actually goes somewhere. -->
        <Button x:Name="MoveBtn"
                cl:Coachmark.Id="btnMove"
                Content="Press me — I move"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="{Binding MovePosition}"
                IsVisible="{Binding IsMoveTargetVisible}"
                Command="{Binding MoveCommand}" />

        <!-- Placed in opposite corners on purpose: the multi-target step spotlights both at once,
             so the two holes end up far apart and the effect is obvious. -->
        <Button x:Name="ConnectBtn"
                cl:Coachmark.Id="btnConnect"
                Content="Connect"
                Width="200"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Command="{Binding ConnectCommand}" />

        <Button x:Name="SettingsBtn"
                cl:Coachmark.Id="btnSettings"
                Content="Settings"
                Width="200"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom" />

        <!-- The first steps of the tour spotlight this one non-interactively, then hide it so the
             step that follows has nothing to point at and gets skipped. -->
        <Button x:Name="VanishBtn"
                cl:Coachmark.Id="btnVanish"
                Content="Look, don't touch"
                Width="200"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                IsVisible="{Binding IsVanishTargetVisible}" />
    </Grid>
</UserControl>
